{% use 'form_div_layout.html.twig' %}

{% block form_row %}
    <div class="mb-4">
        {{ form_label(form) }}
        {{ form_widget(form) }}
        {{ form_errors(form) }}
    </div>
{% endblock %}

{% block form_label %}
    {% if label is not same as(false) %}
        <label for="{{ id }}" class="block text-sm font-medium text-gray-700 mb-1">
            {{ label|default(name|humanize)|trans({}, translation_domain) }}
            {% if required %}<span class="text-red-500">*</span>{% endif %}
        </label>
    {% endif %}
{% endblock %}

{% block form_widget_simple %}
    <input type="{{ type }}" {{ block('widget_attributes') }} {% if value is defined %}value="{{ value }}"{% endif %}
        class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm {{ errors|length > 0 ? 'border-red-500' : '' }}">
{% endblock %}

{% block textarea_widget %}
    <textarea {{ block('widget_attributes') }}
        class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm {{ errors|length > 0 ? 'border-red-500' : '' }}">{{ value }}</textarea>
{% endblock %}

{% block choice_widget_collapsed %}
    <select {{ block('widget_attributes') }} {% if multiple %} multiple{% endif %}
        class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-white">
        {% if placeholder is not none %}
            <option value="">{{ placeholder|trans({}, translation_domain) }}</option>
        {% endif %}
        {% if preferred_choices|length > 0 %}
            {% set options = preferred_choices %}
            {{ block('choice_widget_options') }}
            {% if choices|length > 0 %}<option disabled>---</option>{% endif %}
        {% endif %}
        {% set options = choices %}
        {{ block('choice_widget_options') }}
    </select>
{% endblock %}

{% block choice_widget_expanded %}
    <div {{ block('widget_container_attributes') }} class="space-y-2">
        {% for child in form %}
            <div class="flex items-center">
                {{ form_widget(child, {attr: {class: 'h-4 w-4 text-blue-600 border-gray-300 focus:ring-blue-500'}}) }}
                {{ form_label(child, null, {label_attr: {class: 'ml-2 text-sm text-gray-700'}}) }}
            </div>
        {% endfor %}
    </div>
{% endblock %}

{% block form_errors %}
    {% if errors|length > 0 %}
        {% for error in errors %}
            <p class="mt-1 text-sm text-red-600">{{ error.message }}</p>
        {% endfor %}
    {% endif %}
{% endblock %}
