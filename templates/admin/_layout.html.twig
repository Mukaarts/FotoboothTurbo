{% extends 'base.html.twig' %}

{% block title %}{% block page_title %}Dashboard{% endblock %} — FotoboothTurbo{% endblock %}

{% block body %}
<div class="min-h-screen flex">
    <aside class="w-64 bg-gray-900 text-white flex-shrink-0">
        <div class="p-6">
            <h1 class="text-xl font-bold tracking-tight">FotoboothTurbo</h1>
        </div>
        <nav class="mt-2">
            <a href="{{ path('admin_dashboard') }}"
               class="flex items-center px-6 py-3 text-sm {{ app.current_route == 'admin_dashboard' ? 'bg-gray-800 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }} transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2 2z"/></svg>
                Projekte
            </a>
            <a href="{{ path('admin_project_new') }}"
               class="flex items-center px-6 py-3 text-sm {{ app.current_route == 'admin_project_new' ? 'bg-gray-800 text-white' : 'text-gray-300 hover:bg-gray-800 hover:text-white' }} transition">
                <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                Neues Projekt
            </a>
        </nav>
    </aside>
    <div class="flex-1 flex flex-col">
        <header class="bg-white shadow-sm border-b border-gray-200 px-6 py-4 flex items-center justify-between">
            <h2 class="text-lg font-semibold text-gray-800">{% block header %}Dashboard{% endblock %}</h2>
            <div class="flex items-center gap-4">
                <span class="text-sm text-gray-600">{{ app.user.displayName }}</span>
                <a href="{{ path('app_logout') }}" class="text-sm text-red-600 hover:text-red-800 transition">Abmelden</a>
            </div>
        </header>
        <div class="px-6 pt-4">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div data-controller="flash" class="mb-3 px-4 py-3 rounded-md text-sm
                        {{ type == 'success' ? 'bg-green-50 border border-green-200 text-green-700' : '' }}
                        {{ type == 'error' ? 'bg-red-50 border border-red-200 text-red-700' : '' }}
                        {{ type == 'warning' ? 'bg-yellow-50 border border-yellow-200 text-yellow-700' : '' }}
                        {{ type == 'info' ? 'bg-blue-50 border border-blue-200 text-blue-700' : '' }}
                    ">{{ message }}</div>
                {% endfor %}
            {% endfor %}
        </div>
        <main class="flex-1 p-6">{% block content %}{% endblock %}</main>
    </div>
</div>
{% endblock %}
