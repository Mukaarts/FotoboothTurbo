{% extends 'admin/_layout.html.twig' %}

{% block page_title %}Projekte{% endblock %}
{% block header %}Projekte ({{ total }}){% endblock %}

{% block content %}
    <div class="flex items-center justify-between mb-6">
        <div></div>
        <a href="{{ path('admin_project_new') }}" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition">
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Neues Projekt
        </a>
    </div>

    {% include 'admin/dashboard/_filters.html.twig' %}

    <turbo-frame id="project-list">
        {% if projects|length > 0 %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
                {% for project in projects %}
                    {% include 'admin/dashboard/_project_card.html.twig' %}
                {% endfor %}
            </div>

            {# Pagination #}
            {% if totalPages > 1 %}
                <nav class="flex items-center justify-center gap-2">
                    {% if page > 1 %}
                        <a href="{{ path('admin_dashboard', currentFilters|merge({page: page - 1})) }}" class="px-3 py-1 text-sm text-gray-600 bg-white border border-gray-300 rounded hover:bg-gray-50 transition">&laquo; Zurück</a>
                    {% endif %}

                    {% for p in range(1, totalPages) %}
                        {% if p == page %}
                            <span class="px-3 py-1 text-sm text-white bg-blue-600 rounded">{{ p }}</span>
                        {% else %}
                            <a href="{{ path('admin_dashboard', currentFilters|merge({page: p})) }}" class="px-3 py-1 text-sm text-gray-600 bg-white border border-gray-300 rounded hover:bg-gray-50 transition">{{ p }}</a>
                        {% endif %}
                    {% endfor %}

                    {% if page < totalPages %}
                        <a href="{{ path('admin_dashboard', currentFilters|merge({page: page + 1})) }}" class="px-3 py-1 text-sm text-gray-600 bg-white border border-gray-300 rounded hover:bg-gray-50 transition">Weiter &raquo;</a>
                    {% endif %}
                </nav>
            {% endif %}
        {% else %}
            <div class="text-center py-16">
                <svg class="mx-auto w-12 h-12 text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                <p class="text-gray-500 text-sm mb-4">Noch keine Projekte vorhanden.</p>
                <a href="{{ path('admin_project_new') }}" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition">
                    Erstes Projekt erstellen
                </a>
            </div>
        {% endif %}
    </turbo-frame>
{% endblock %}
