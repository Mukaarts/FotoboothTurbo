<div class="bg-white rounded-lg shadow-sm border border-gray-200 p-5 hover:shadow-md transition">
    <div class="flex items-start justify-between mb-3">
        <a href="{{ path('admin_project_show', {id: project.id}) }}" class="text-sm font-semibold text-gray-900 hover:text-blue-600 transition truncate">
            {{ project.title }}
        </a>
        <span class="ml-2 flex-shrink-0 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
            {{ project.status.badgeColor == 'gray' ? 'bg-gray-100 text-gray-700' : '' }}
            {{ project.status.badgeColor == 'yellow' ? 'bg-yellow-100 text-yellow-700' : '' }}
            {{ project.status.badgeColor == 'orange' ? 'bg-orange-100 text-orange-700' : '' }}
            {{ project.status.badgeColor == 'green' ? 'bg-green-100 text-green-700' : '' }}
            {{ project.status.badgeColor == 'blue' ? 'bg-blue-100 text-blue-700' : '' }}
            {{ project.status.badgeColor == 'slate' ? 'bg-slate-100 text-slate-700' : '' }}
        ">
            {{ project.status.label }}
        </span>
    </div>

    <div class="text-sm text-gray-600 space-y-1 mb-4">
        <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            <span>{{ project.customer.name }}</span>
            {% if project.customer.company %}
                <span class="text-gray-400">/ {{ project.customer.company }}</span>
            {% endif %}
        </div>
        <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            <span>{{ project.event.eventDate|date('d.m.Y') }}</span>
        </div>
        <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="truncate">{{ project.event.location }}</span>
        </div>
    </div>

    <div class="flex items-center gap-2 border-t border-gray-100 pt-3">
        {% if project.customerLink %}
            <button type="button" data-controller="clipboard" data-clipboard-text-value="{{ project.customerLink.token }}"
                data-action="click->clipboard#copy"
                class="text-xs text-blue-600 hover:text-blue-800 transition cursor-pointer">
                Link kopieren
            </button>
        {% endif %}
        <span class="text-xs text-gray-300">|</span>
        <span class="text-xs text-gray-400 cursor-not-allowed" title="Kommt in einer späteren Version">Export</span>
        <span class="text-xs text-gray-300">|</span>
        <a href="{{ path('admin_project_show', {id: project.id}) }}" class="text-xs text-blue-600 hover:text-blue-800 transition">Details</a>
    </div>
</div>
